# PostgreSQL — Neon
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"

# JWT
JWT_SECRET="REEMPLAZA_CON_CLAVE_SEGURA_DE_64_CHARS"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3001
NODE_ENV=production

# Frontend (para CORS)
FRONTEND_URL="https://tu-app.vercel.app,https://www.tu-app.vercel.app"

# Email — Gmail
# MAIL_USER: tu cuenta de Gmail
# MAIL_PASS: App Password (no la contraseña real)
#   Cómo obtener App Password:
#   1. Ir a myaccount.google.com
#   2. Seguridad → Verificación en 2 pasos (activar si no está)
#   3. Seguridad → Contraseñas de aplicaciones
#   4. Seleccionar "Correo" y "Otro" → generar
#   5. Copiar la clave de 16 caracteres acá abajo
MAIL_USER="tu@gmail.com"
MAIL_PASS="xxxx xxxx xxxx xxxx"
