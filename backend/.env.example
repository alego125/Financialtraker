# ============================================================
# VARIABLES DE ENTORNO — BACKEND
# ============================================================
# Copiá este archivo como .env y completá los valores

# PostgreSQL — obtené esta URL desde Neon (https://neon.tech)
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"

# JWT — generá una clave segura: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REEMPLAZA_CON_CLAVE_SEGURA_DE_64_CHARS"
JWT_EXPIRES_IN="7d"

# Puerto (Railway lo setea automáticamente, no tocar)
PORT=3001

# Entorno
NODE_ENV=production

# URL del frontend (Vercel te da esta URL al hacer deploy)
FRONTEND_URL="https://tu-app.vercel.app"
