generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum PartnershipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum PaymentType {
  EFECTIVO
  DEBITO
  CREDITO
  TRANSFERENCIA
}

enum AccountType {
  REGULAR
  INVESTMENT
  CREDIT
}

enum Currency {
  ARS
  USD
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  categories   Category[]
  transactions Transaction[]
  accounts     Account[]
  sentPartnerships     Partnership[] @relation("PartnershipSender")
  receivedPartnerships Partnership[] @relation("PartnershipReceiver")
  sharedAccountsA      SharedAccount[] @relation("SharedAccountUserA")
  sharedAccountsB      SharedAccount[] @relation("SharedAccountUserB")
  initiatedTransfers   Transfer[] @relation("TransferInitiator")
  currencyExchanges    CurrencyExchange[]
  sharedAccountExchanges SharedAccountExchange[]
}

model Partnership {
  id         String            @id @default(uuid())
  senderId   String
  receiverId String
  status     PartnershipStatus @default(PENDING)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  sender     User              @relation("PartnershipSender",   fields: [senderId],   references: [id], onDelete: Cascade)
  receiver   User              @relation("PartnershipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
}

model Account {
  id               String      @id @default(uuid())
  name             String
  accountType      AccountType @default(REGULAR)
  initialBalance   Decimal     @default(0) @db.Decimal(12, 2)
  initialBalanceUSD Decimal    @default(0) @db.Decimal(12, 2)
  color            String      @default("#6366f1")
  userId           String
  createdAt        DateTime    @default(now())
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     Transaction[]
  transfersFrom    Transfer[]  @relation("TransferFromPersonal")
  transfersTo      Transfer[]  @relation("TransferToPersonal")
  exchangesFrom    CurrencyExchange[]

  @@unique([userId, name])
  @@index([userId])
}

model SharedAccount {
  id               String    @id @default(uuid())
  name             String
  initialBalance   Decimal   @default(0) @db.Decimal(12, 2)
  color            String    @default("#7c3aed")
  accountType      AccountType @default(REGULAR)
  initialBalanceUSD Decimal   @default(0) @db.Decimal(12, 2)
  userAId          String
  userBId          String
  createdAt        DateTime  @default(now())
  userA            User      @relation("SharedAccountUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB            User      @relation("SharedAccountUserB", fields: [userBId], references: [id], onDelete: Cascade)
  transactions     Transaction[]
  transfersFrom    Transfer[] @relation("TransferFromShared")
  transfersTo      Transfer[] @relation("TransferToShared")
  exchangesFrom    SharedAccountExchange[]

  @@index([userAId])
  @@index([userBId])
}

model Category {
  id           String          @id @default(uuid())
  name         String
  type         TransactionType
  color        String          @default("#6366f1")
  userId       String
  createdAt    DateTime        @default(now())
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, name])
  @@index([userId])
}

model Transaction {
  id              String          @id @default(uuid())
  type            TransactionType
  amount          Decimal         @db.Decimal(12, 2)
  currency        Currency        @default(ARS)
  comment         String?
  date            DateTime
  paymentType     PaymentType?
  userId          String
  categoryId      String
  accountId       String?
  sharedAccountId String?
  transferId      String?
  isReimbursement Boolean         @default(false)
  createdAt       DateTime        @default(now())
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        Category        @relation(fields: [categoryId], references: [id])
  account         Account?        @relation(fields: [accountId], references: [id])
  sharedAccount   SharedAccount?  @relation(fields: [sharedAccountId], references: [id])
  transfer        Transfer?       @relation(fields: [transferId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([date])
  @@index([categoryId])
  @@index([type])
  @@index([paymentType])
  @@index([currency])
  @@index([accountId])
  @@index([sharedAccountId])
  @@index([transferId])
}

model Transfer {
  id                  String         @id @default(uuid())
  amount              Decimal        @db.Decimal(12, 2)
  currency            Currency       @default(ARS)
  date                DateTime
  comment             String?
  createdAt           DateTime       @default(now())
  initiatorId         String
  fromAccountId       String?
  fromSharedAccountId String?
  toAccountId         String?
  toSharedAccountId   String?
  initiator           User           @relation("TransferInitiator",   fields: [initiatorId],         references: [id], onDelete: Cascade)
  fromAccount         Account?       @relation("TransferFromPersonal", fields: [fromAccountId],       references: [id])
  fromSharedAccount   SharedAccount? @relation("TransferFromShared",   fields: [fromSharedAccountId], references: [id])
  toAccount           Account?       @relation("TransferToPersonal",   fields: [toAccountId],         references: [id])
  toSharedAccount     SharedAccount? @relation("TransferToShared",     fields: [toSharedAccountId],   references: [id])
  transactions        Transaction[]

  @@index([initiatorId])
  @@index([date])
  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([fromSharedAccountId])
  @@index([toSharedAccountId])
}

// Compra/venta de divisas dentro de una cuenta
model CurrencyExchange {
  id          String   @id @default(uuid())
  accountId   String
  userId      String
  date        DateTime
  usdAmount   Decimal  @db.Decimal(12, 2)  // USD comprados (+) o vendidos (-)
  arsAmount   Decimal  @db.Decimal(12, 2)  // ARS debitados (+) o acreditados (-)
  rate        Decimal  @db.Decimal(12, 4)  // precio de compra (ARS/USD)
  comment     String?
  createdAt   DateTime @default(now())
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([userId])
  @@index([date])
}

// Compra/venta de divisas dentro de una cuenta compartida
model SharedAccountExchange {
  id               String        @id @default(uuid())
  sharedAccountId  String
  userId           String
  date             DateTime
  usdAmount        Decimal       @db.Decimal(12, 2)
  arsAmount        Decimal       @db.Decimal(12, 2)
  rate             Decimal       @db.Decimal(12, 4)
  comment          String?
  createdAt        DateTime      @default(now())
  sharedAccount    SharedAccount @relation(fields: [sharedAccountId], references: [id], onDelete: Cascade)
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sharedAccountId])
  @@index([userId])
  @@index([date])
}
